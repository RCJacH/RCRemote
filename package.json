{
  "name": "rcremote",
  "version": "1.0.0",
  "description": "Web Remote Controller for Recording with REAPER",
  "main": "index.js",
  "scripts": {
    "build:pug": "pug -P -p assets/pug/index.pug < assets/pug/index.pug > dists/RCRemote.html",
    "watch:pug": "watch \"npm run build:pug\" assets/pug",
    "build:css": "postcss assets/css/index.css --output dists/RCRemote.css",
    "build:css:dev": "npm run build:css -- --env development",
    "watch:css": "watch \"npm run build:css:dev\" assets/css",
    "build:js": "webpack --entry ./assets/js/index.js",
    "watch:js": "watch \"npm run build:js\" assets/js",
    "build:ts": "npx tsc assets/ts/RCRemote.ts --out dists/RCRemote.js",
    "watch:ts": "npm run build:ts -- -w assets/ts",
    "build": "webpack",
    "watch": "webpack --watch",
    "serve": "webpack serve",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production"
  },
  "browserslist": [
    "> 0.2%",
    "last 10 versions",
    "Firefox ESR",
    "not dead",
    "iOS 8"
  ],
  "author": "RCJacH",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "autoprefixer": "^10.2.5",
    "css-loader": "^5.2.1",
    "cssmin": "^0.4.3",
    "cssnano": "^4.1.11",
    "html-webpack-plugin": "^5.3.1",
    "mini-css-extract-plugin": "^1.4.1",
    "postcss": "^8.2.10",
    "postcss-cli": "^8.3.1",
    "postcss-functions": "^4.0.2",
    "postcss-import": "^14.0.1",
    "postcss-loader": "^5.2.0",
    "postcss-mixins": "^7.0.3",
    "postcss-preset-env": "^6.7.0",
    "postcss-scss": "^3.0.5",
    "precss": "^4.0.0",
    "pug": "^3.0.2",
    "pug-cli": "^1.0.0-alpha6",
    "simple-pug-loader": "^0.1.2",
    "style-loader": "^2.0.0",
    "ts-loader": "^8.1.0",
    "tsc": "^1.20150623.0",
    "typescript": "^4.2.4",
    "webpack": "^5.32.0",
    "webpack-cli": "^4.6.0",
    "webpack-dev-server": "^3.11.2",
    "webpack-merge": "^5.7.3"
  }
}
